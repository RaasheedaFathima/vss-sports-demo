# VSS2 Secret — sensitive credentials
# DO NOT commit a filled-in version of this file to source control.
# Use kubectl apply or a secrets manager (Vault, OCI Vault, Sealed Secrets).
apiVersion: v1
kind: Secret
metadata:
  name: vss2-app-secret
  namespace: default
type: Opaque
stringData:
  # PostgreSQL password (must match the postgres StatefulSet below)
  PG_PASSWORD: "<YOUR_PG_PASSWORD>"

  # NVIDIA NIM API key — obtain from https://build.nvidia.com/
  # Leave empty if only using OCI GenAI models.
  NVIDIA_API_KEY: ""

  # Local NIM API key (leave empty if your local NIM needs no auth)
  LOCAL_COSMOS_API_KEY: ""
