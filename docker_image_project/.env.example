# Single OCIR image used by both the app and worker containers.
OCIR_REGION=us-ashburn-1
CONTAINER_REGISTRY=ocir.us-ashburn-1.oci.oraclecloud.com
TENANCY_NAMESPACE=idxkccw2srke
IMAGE_NAME=ai_demo
IMAGE_TAG=demo
APP_PORT=8000

# Oracle ADB connection.
# Use either a full connect descriptor or a wallet alias such as dbname_high.
ADB_USER=your_adb_user
ADB_PASSWORD=your_adb_password
ADB_DSN=your_adb_connect_descriptor_or_wallet_alias

# If your ADB connection uses a wallet, place wallet files in ./wallet
# or set ADB_WALLET_HOST_DIR to an absolute host path.
ADB_WALLET_DIR=/wallet
ADB_WALLET_HOST_DIR=./wallet

# OCI GenAI settings used by the existing source code.
# The current app and worker use OCI instance principal authentication.
COMPARTMENT_ID=ocid1.compartment.oc1..example
GEMINI_25_PRO_OCID=ocid1.generativeaimodel.oc1..example
GEMINI_25_FLASH_OCID=ocid1.generativeaimodel.oc1..example
COHERE_CMD_A_VISION=ocid1.generativeaimodel.oc1..example

# Optional NVIDIA public NIM settings.
NVIDIA_API_KEY=
COSMOS_REASON2_MODEL=nvidia/cosmos-reason2-8b
NVIDIA_NIM_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions

# Optional local/self-hosted NIM settings.
LOCAL_COSMOS_ENDPOINT=
LOCAL_COSMOS_API_KEY=
LOCAL_COSMOS_MODEL=nvidia/cosmos-reason2-8b
